<div id="fractal-dashboard" class="container mt-5 mb-5" v-cloak>

    <div class="row mb-4">
        <div class="col-12">
            <h1 class="border-bottom border-dark pb-2 text-dark font-weight-bold">Фрактальный анализ структуры бетона</h1>
            <p class="lead text-muted mt-3">
                Данная система предназначена для анализа микроструктуры бетонных срезов с использованием методов фрактальной геометрии.
                Анализ позволяет оценить сложность структуры материала и выявить закономерности распределения пор и трещин.
            </p>
        </div>
    </div>

    <div class="row">
        <div class="col-md-5 mb-4">

            <div class="card border-dark mb-4 rounded-0">
                <div class="card-header bg-white border-dark text-dark font-weight-bold">
                    <h5 class="mb-0">Инструкция</h5>
                </div>
                <div class="card-body">
                    <ul class="mb-0 pl-3 text-muted">
                        <li>Загрузите изображение среза бетона</li>
                        <li>Поддерживаемые форматы: <strong>JPG, PNG, BMP</strong></li>
                        <li>После загрузки будет выполнен фрактальный анализ</li>
                    </ul>
                </div>
            </div>

            <div class="card border-dark rounded-0">
                <div class="card-header bg-white border-dark text-dark font-weight-bold">
                    <h5 class="mb-0">Загрузка изображения</h5>
                </div>
                <div class="card-body">
                    <form id="uploadForm">
                        <div class="form-group">
                            <input type="file" class="form-control-file" id="imageInput" accept=".jpg,.jpeg,.png,.bmp" required />
                        </div>
                        <button type="submit" id="submitBtn" class="btn btn-dark btn-block rounded-0 mt-3">
                            Загрузить и проанализировать
                        </button>
                    </form>
                </div>
            </div>

        </div>

        <div class="col-md-7 mb-4">
            <div class="card border-dark h-100 rounded-0">
                <div class="card-header bg-dark text-white font-weight-bold">
                    <h5 class="mb-0">Результаты анализа</h5>
                </div>
                <div class="card-body d-flex flex-column">

                    <div id="resultBox" class="alert alert-light border border-dark rounded-0 text-center mb-4">
                        Размер: ... байт. Настройте порог белого.
                    </div>

                    <div id="analysis-section" class="mt-auto border-top border-dark pt-4">

                        <div class="text-center mb-4">
                            <canvas id="canvas" class="img-fluid border border-dark mb-3"></canvas>

                            <div class="d-flex align-items-center justify-content-center">
                                <label class="font-weight-bold text-dark mb-0 mr-2">Уровень белого (Порог):</label>
                                <input type="range" class="custom-range w-50" id="thresholdRange" min="0" max="255" value="128">
                                <span id="thresholdValue" class="badge badge-dark rounded-0 ml-2">128</span>
                            </div>
                        </div>

                        <h6 class="text-center font-weight-bold mt-5">График Box-Counting</h6>
                        <canvas id="fractalChart" style="max-height: 300px; width: 100%;"></canvas>

                        <button id="saveBtn" class="btn btn-outline-dark btn-block rounded-0 mt-4">Сохранить результат</button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<%- /* Expose server-rendered data as window.SAILS_LOCALS :: */ exposeLocalsToBrowser() %>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

<script>
  window.addEventListener('load', function() {
    let myChart = null;

    document.getElementById('uploadForm').addEventListener('submit', async function(event) {
      event.preventDefault();

      const fileInput = document.getElementById('imageInput');
      const submitBtn = document.getElementById('submitBtn');
      const resultBox = document.getElementById('resultBox');

      const file = fileInput.files[0];
      if (!file) return;

      submitBtn.innerText = "Идет анализ на сервере... ⏳";
      submitBtn.disabled = true;

      const formData = new FormData();
      formData.append('image', file);
      // Отправляем заодно и текущий порог
      formData.append('threshold', document.getElementById('thresholdRange').value);

      try {
        const response = await axios.post('/api/v1/concrete/analyze', formData, {
          headers: { 'Content-Type': 'multipart/form-data' }
        });

        const data = response.data;

        resultBox.innerHTML = `
                <h4 class="text-success mb-2">Анализ завершен!</h4>
                <p class="mb-0" style="font-size: 1.2rem;">Фрактальная размерность (D): <strong>${data.dimension}</strong></p>
            `;

        const ctx = document.getElementById('fractalChart').getContext('2d');
        if (myChart) myChart.destroy();

        const points = data.graphData.x.map((xVal, index) => ({ x: xVal, y: data.graphData.y[index] }));

        myChart = new Chart(ctx, {
          type: 'scatter',
          data: {
            datasets: [{
              label: 'Зависимость log(N) от log(1/s)',
              data: points,
              backgroundColor: 'black'
            }]
          },
          options: {
            scales: {
              x: { title: { display: true, text: 'log(1/s)' } },
              y: { title: { display: true, text: 'log(N)' } }
            }
          }
        });

      } catch (error) {
        console.error("Ошибка сети:", error);
        resultBox.innerHTML = `<span class="text-danger font-weight-bold">Проверьте консоль сервера (Sails). Маршрут не найден или ошибка в коде контроллера.</span>`;
      } finally {
        submitBtn.innerText = "Загрузить и проанализировать";
        submitBtn.disabled = false;
      }
    });
  });
</script>
